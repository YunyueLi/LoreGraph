# Anthropic API key — required to run extraction passes.
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string. Must use the async driver `asyncpg`.
DATABASE_URL=postgresql+asyncpg://litgraph:litgraph@localhost:5432/litgraph

# Claude model used for extraction. Sonnet 4.6 is the default; Opus 4.7 is
# available for higher-fidelity passes (5/6) at higher cost.
LITGRAPH_MODEL=claude-sonnet-4-6

# Log level: DEBUG | INFO | WARNING | ERROR
LITGRAPH_LOG_LEVEL=INFO

# Per-book hard ceiling on LLM spend, in USD. The orchestrator aborts the
# pipeline if cumulative cost exceeds this value.
LITGRAPH_COST_CEILING_USD=20.0
