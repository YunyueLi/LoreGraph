# ════════════════════════════════════════════════════════════════════
# LoreGraph environment variables
# ════════════════════════════════════════════════════════════════════

# ── LLM provider ────────────────────────────────────────────────────
# Which backend the pipeline uses for Pass-2 onward.
#
# Built-in presets (Anthropic is native; the rest dispatch through the
# OpenAI-compatible SDK and need only the right base_url + api_key):
#
#   anthropic   · Claude · native SDK, keeps prompt caching
#   openai      · GPT-4o / GPT-5 / o-series
#   deepseek    · deepseek-chat / deepseek-reasoner
#   kimi        · Moonshot · moonshot-v1-32k / -128k
#   zhipu       · 智谱 · glm-4-plus / glm-4-air
#   qwen        · 阿里 DashScope · qwen-max / qwen-plus
#   groq        · llama-3.3-70b · ultra-low latency
#   grok        · xAI · grok-3
#   gemini      · Google Gemini via OpenAI-compat endpoint · gemini-2.0-flash
#   together    · meta-llama / mixtral hosted
#   fireworks   · accounts/fireworks/models/llama-v3p3-70b-instruct
#   mistral     · mistral-large-latest
#   openrouter  · 200+ models through one endpoint · default anthropic/claude-3.5-sonnet
#                 (override via LOREGRAPH_LLM_MODEL, e.g. anthropic/claude-sonnet-4,
#                  openai/gpt-4o, deepseek/deepseek-chat, meta-llama/llama-3.3-70b-instruct)
#   ollama      · localhost:11434 · any model you've pulled
#   vllm        · localhost:8000 · self-hosted
#   openai_compatible · custom endpoint — must set LOREGRAPH_LLM_BASE_URL
LOREGRAPH_LLM_PROVIDER=anthropic

# Generic API key. If set, takes precedence over the provider-specific
# env vars below. Useful when swapping providers without renaming vars.
# LOREGRAPH_LLM_API_KEY=

# Override the provider's default base_url (OpenAI-compatible only).
# Required when LOREGRAPH_LLM_PROVIDER=openai_compatible.
# LOREGRAPH_LLM_BASE_URL=

# Override the provider's default model. Each preset ships with a sane
# default (e.g. claude-sonnet-4-6 for anthropic, gpt-4o for openai,
# deepseek-chat for deepseek). Set this to use a different one.
# LOREGRAPH_LLM_MODEL=

# ── Provider-specific keys ──────────────────────────────────────────
# The client falls back to whichever of these is set, in this order:
#   1. LOREGRAPH_LLM_API_KEY (above)
#   2. The provider's canonical env var below
#
# Anthropic
ANTHROPIC_API_KEY=

# OpenAI (and most OpenAI-compatible providers also accept these names):
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=
# ZHIPU_API_KEY=
# DASHSCOPE_API_KEY=
# GROQ_API_KEY=
# XAI_API_KEY=
# GEMINI_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=

# ── Storage ─────────────────────────────────────────────────────────
# PostgreSQL connection string. Must use the async driver `asyncpg`.
DATABASE_URL=postgresql+asyncpg://loregraph:loregraph@localhost:5432/loregraph

# ── Cost & logging ──────────────────────────────────────────────────
# Per-book hard ceiling on LLM spend, in USD. The orchestrator aborts
# the pipeline if cumulative cost exceeds this value.
LOREGRAPH_COST_CEILING_USD=20.0

# Log level: DEBUG | INFO | WARNING | ERROR
LOREGRAPH_LOG_LEVEL=INFO

# ── Web ─────────────────────────────────────────────────────────────
# CORS allow-list for the FastAPI server. Comma-separated origins, or
# "*" to allow any (only for local dev). In production, set this to
# your Cloudflare Pages URL: "https://loregraph.pages.dev".
LOREGRAPH_CORS_ORIGINS=*

# ── Legacy ──────────────────────────────────────────────────────────
# Anthropic-only model alias, kept for back-compat. Prefer LOREGRAPH_LLM_MODEL.
LOREGRAPH_MODEL=claude-sonnet-4-6
