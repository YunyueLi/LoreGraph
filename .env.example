# Anthropic API key — required to run extraction passes.
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string. Must use the async driver `asyncpg`.
DATABASE_URL=postgresql+asyncpg://loregraph:loregraph@localhost:5432/loregraph

# Claude model used for extraction. Sonnet 4.6 is the default; Opus 4.7 is
# available for higher-fidelity passes (5/6) at higher cost.
LOREGRAPH_MODEL=claude-sonnet-4-6

# Log level: DEBUG | INFO | WARNING | ERROR
LOREGRAPH_LOG_LEVEL=INFO

# Per-book hard ceiling on LLM spend, in USD. The orchestrator aborts the
# pipeline if cumulative cost exceeds this value.
LOREGRAPH_COST_CEILING_USD=20.0

# CORS allow-list for the FastAPI server. Comma-separated origins, or "*"
# to allow any (only for local dev). In production, set this to your
# Cloudflare Pages URL: "https://loregraph.pages.dev".
LOREGRAPH_CORS_ORIGINS=*
