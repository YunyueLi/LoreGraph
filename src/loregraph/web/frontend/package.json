{
  "name": "loregraph-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "React + Vite + Cytoscape frontend for LoreGraph.",
  "scripts": {
    "dev": "vite",
    "dev:demo": "VITE_DEMO_MODE=1 vite",
    "build": "tsc --noEmit && vite build",
    "build:demo": "tsc --noEmit && VITE_DEMO_MODE=1 VITE_BASE=/LoreGraph/ vite build",
    "build:landing": "node ../build-landing.cjs",
    "deploy": "npm run build:landing && gh-pages -d dist -b gh-pages -t -m \"deploy: update landing page\"",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "cytoscape": "^3.30.2",
    "cytoscape-cose-bilkent": "^4.1.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
